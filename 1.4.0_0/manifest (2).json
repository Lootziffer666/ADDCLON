{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "config.js", "safe-storage.js", "analytics-v2.js", "lib/html-to-pdfmake.min.js", "lib/pdfmake.min.js", "lib/vfs_fonts.js", "gemini-storage.js", "api-client.js", "prompt_library.js", "word_counter.js", "enhance_prompt.js", "content_gemini.js", "pinned_messages.js", "injector.js" ],
      "matches": [ "*://gemini.google.com/*" ],
      "run_at": "document_idle"
   } ],
