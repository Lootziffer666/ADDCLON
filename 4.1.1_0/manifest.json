   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "ruleset_1",
         "path": "rules/request_modifier_rule.json"
      } ]
   },
   "default_locale": "en",
   "description": "__MSG_extensionDescription__",
   "host_permissions": [ "*://*/*" ],
   "icons": {
      "128": "icon-128.png",
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_extensionName__",
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "tabs", "storage", "cookies", "declarativeNetRequest", "sidePanel" ],
   "side_panel": {
      "default_path": "sidepanel.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "4.1.1",
   "web_accessible_resources": [ {
