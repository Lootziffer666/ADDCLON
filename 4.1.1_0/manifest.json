      "run_at": "document_idle"
   }, {
      "include_globs": [  ],
      "js": [ "content-scripts/saveai.js" ],
      "matches": [ "https://saveai.net/*", "https://www.saveai.net/*" ],
      "run_at": "document_start"
   }, {
      "js": [ "content-scripts/start.js" ],
