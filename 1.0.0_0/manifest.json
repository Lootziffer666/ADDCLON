{
   "action": {
      "default_icon": {
         "16": "icons/icon-16.png",
         "32": "icons/icon-32.png"
      },
      "default_title": "No Code Web Scraper"
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "\u003Call_urls>" ],
      "run_at": "document_idle"
   } ],
   "description": "Scrape any website visually. Click elements, preview data, export to Excel/CSV. No coding required.",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icons/icon-128.png",
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "No Code Web Scraper",
   "permissions": [ "activeTab", "sidePanel", "storage", "downloads", "tabs", "scripting" ],
   "side_panel": {
      "default_path": "src/sidepanel/index.html"
   },
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.0"
}
