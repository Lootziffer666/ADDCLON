{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "open-gemini": {
         "description": "Open Gemini in a new tab",
         "suggested_key": {
            "default": "Alt+Shift+G"
         }
      }
   },
   "content_scripts": [ {
      "js": [ "spoof_injector.js" ],
      "matches": [ "*://gemini.google.com/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "css": [ "content.css" ],
      "js": [ "lib/docx.umd.min.js", "lib/jspdf.umd.min.js", "lib/jspdf-autotable.min.js", "lib/pdf-fonts.js", "content.js" ],
      "matches": [ "*://gemini.google.com/*" ],
      "run_at": "document_end"
   } ],
   "default_locale": "en",
   "description": "__MSG_extDescription__",
   "host_permissions": [ "*://gemini.google.com/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Superpower for Gemini™",
   "permissions": [ "activeTab", "tabs", "storage", "scripting", "webRequest", "unlimitedStorage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1.18",
   "web_accessible_resources": [ {
      "matches": [ "*://gemini.google.com/*" ],
      "resources": [ "content.css", "popup.css", "icons/icon48.png", "guide.html", "guide.js", "welcome.html", "welcome.js", "lib/docx.umd.min.js", "lib/jspdf.umd.min.js", "lib/jspdf-autotable.min.js", "lib/pdf-fonts.js" ]
   } ]
}
